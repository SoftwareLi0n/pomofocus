<Window x:Class="FocusPomodoro.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuracion" 
        Height="380"
        Width="300"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Style x:Key="TitleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#aaa"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Width="28" Height="28">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#ff4757"/>
                    <Setter Property="Background" Value="#ffffff15"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SaveButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4ade8090"/>
            <Setter Property="Foreground" Value="#fff"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5eeea0a0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="15" 
            Background="#1a1a2ec0" 
            BorderBrush="#ffffff15" 
            BorderThickness="1"
            x:Name="MainBorder">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="Configuracion" 
                           FontSize="18" FontWeight="Bold" 
                           Foreground="#00d9ff" VerticalAlignment="Center"/>
                <Button x:Name="CloseBtn" Content="×" 
                        Width="30" Height="30" 
                        HorizontalAlignment="Right"
                        Click="CloseBtn_Click"
                        Style="{StaticResource TitleButtonStyle}"/>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="Tiempo de concentracion (minutos)" 
                           FontSize="11" Foreground="#aaa" Margin="0,0,0,5"/>
                <TextBox x:Name="FocusMinutesTextBox"
                         Text="50" FontSize="14"
                         Background="#2d2d4480"
                         Foreground="#fff"
                         BorderThickness="0"
                         Padding="10,8"
                         VerticalContentAlignment="Center"
                         PreviewTextInput="NumericOnly_PreviewTextInput"
                         InputScope="Number"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,15">
                <TextBlock Text="Tiempo de descanso (minutos)" 
                           FontSize="11" Foreground="#aaa" Margin="0,0,0,5"/>
                <TextBox x:Name="BreakMinutesTextBox"
                         Text="10" FontSize="14"
                         Background="#2d2d4480"
                         Foreground="#fff"
                         BorderThickness="0"
                         Padding="10,8"
                         VerticalContentAlignment="Center"
                         PreviewTextInput="NumericOnly_PreviewTextInput"
                         InputScope="Number"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,0,0,15">
                <TextBlock x:Name="OpacityLabel"
                           Text="Opacidad: 75%" 
                           FontSize="11" Foreground="#aaa" Margin="0,0,0,5"/>
                <Slider x:Name="OpacitySlider" 
                        Minimum="0.3" Maximum="1.0" 
                        Value="0.75" 
                        SmallChange="0.05" 
                        LargeChange="0.1"
                        ValueChanged="OpacitySlider_ValueChanged"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Margin="0,0,0,15">
                <TextBlock Text="Nivel de concentracion"
                           FontSize="11" Foreground="#aaa" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="ModerateRadio" Content="Moderado"
                                 Foreground="#aaa" FontSize="12" Margin="0,0,20,0"
                                 IsChecked="True" GroupName="ConcentrationLevel"/>
                    <RadioButton x:Name="DrasticRadio" Content="Drastico"
                                 Foreground="#ff4757" FontSize="12" FontWeight="Bold"
                                 GroupName="ConcentrationLevel"/>
                </StackPanel>
                <TextBlock x:Name="LevelDescription"
                           Text="Permite pausar, resetear y saltar descanso"
                           FontSize="10" Foreground="#666" Margin="0,5,0,0"/>
            </StackPanel>

            <Button Grid.Row="5"
                    Content="Guardar"
                    Click="SaveBtn_Click"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource SaveButtonStyle}"/>
        </Grid>
    </Border>
</Window>
