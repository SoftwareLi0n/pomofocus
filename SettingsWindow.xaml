<Window x:Class="FocusPomodoro.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuracion" 
        Height="450"
        Width="300"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Style x:Key="TitleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#aaa"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Width="28" Height="28">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#ff4757"/>
                    <Setter Property="Background" Value="#ffffff15"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SaveButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4ade8090"/>
            <Setter Property="Foreground" Value="#fff"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5eeea0a0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WorkHoursComboStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#2d2d4480"/>
            <Setter Property="Foreground" Value="#fff"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                          Focusable="False" 
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="#2d2d4480" CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"/>
                                                <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0" 
                                                      Fill="#fff" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" 
                                              IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,0,20,0" 
                                              VerticalAlignment="Center" 
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" 
                                   Placement="Bottom" 
                                   IsOpen="{TemplateBinding IsDropDownOpen}" 
                                   AllowsTransparency="True" 
                                   Focusable="False" 
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown" 
                                      SnapsToDevicePixels="True" 
                                      MinWidth="{TemplateBinding ActualWidth}" 
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" 
                                            Background="#2d2d4480" 
                                            CornerRadius="4"
                                            Margin="0,2,0,0"/>
                                    <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WorkHoursItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2d2d4480"/>
            <Setter Property="Foreground" Value="#fff"/>
            <Setter Property="Padding" Value="8,4"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#4d4d6690"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="15" 
            Background="#1a1a2ec0" 
            BorderBrush="#ffffff15" 
            BorderThickness="1"
            x:Name="MainBorder">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="Configuracion" 
                           FontSize="18" FontWeight="Bold" 
                           Foreground="#00d9ff" VerticalAlignment="Center"/>
                <Button x:Name="CloseBtn" Content="×" 
                        Width="30" Height="30" 
                        HorizontalAlignment="Right"
                        Click="CloseBtn_Click"
                        Style="{StaticResource TitleButtonStyle}"/>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="Tiempo de concentracion (minutos)" 
                           FontSize="11" Foreground="#aaa" Margin="0,0,0,5"/>
                <TextBox x:Name="FocusMinutesTextBox"
                         Text="50" FontSize="14"
                         Background="#2d2d4480"
                         Foreground="#fff"
                         BorderThickness="0"
                         Padding="10,8"
                         VerticalContentAlignment="Center"
                         PreviewTextInput="NumericOnly_PreviewTextInput"
                         InputScope="Number"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,15">
                <TextBlock Text="Tiempo de descanso (minutos)" 
                           FontSize="11" Foreground="#aaa" Margin="0,0,0,5"/>
                <TextBox x:Name="BreakMinutesTextBox"
                         Text="10" FontSize="14"
                         Background="#2d2d4480"
                         Foreground="#fff"
                         BorderThickness="0"
                         Padding="10,8"
                         VerticalContentAlignment="Center"
                         PreviewTextInput="NumericOnly_PreviewTextInput"
                         InputScope="Number"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,0,0,15">
                <TextBlock x:Name="OpacityLabel"
                           Text="Opacidad: 75%" 
                           FontSize="11" Foreground="#aaa" Margin="0,0,0,5"/>
                <Slider x:Name="OpacitySlider" 
                        Minimum="0.3" Maximum="1.0" 
                        Value="0.75" 
                        SmallChange="0.05" 
                        LargeChange="0.1"
                        ValueChanged="OpacitySlider_ValueChanged"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Margin="0,0,0,15">
                <TextBlock Text="Nivel de concentracion"
                           FontSize="11" Foreground="#aaa" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="ModerateRadio" Content="Moderado"
                                 Foreground="#aaa" FontSize="12" Margin="0,0,20,0"
                                 IsChecked="True" GroupName="ConcentrationLevel"/>
                    <RadioButton x:Name="DrasticRadio" Content="Drastico"
                                 Foreground="#ff4757" FontSize="12" FontWeight="Bold"
                                 GroupName="ConcentrationLevel"/>
                </StackPanel>
                <TextBlock x:Name="LevelDescription"
                           Text="Permite pausar, resetear y saltar descanso"
                           FontSize="10" Foreground="#666" Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="5" Margin="0,0,0,15">
                <TextBlock Text="Horario de trabajo"
                           FontSize="11" Foreground="#aaa" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Inicio" FontSize="10" Foreground="#666" Margin="0,0,0,5"/>
                        <ComboBox x:Name="StartHourCombo" Style="{StaticResource WorkHoursComboStyle}" ItemContainerStyle="{StaticResource WorkHoursItemStyle}"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Column="1" Text="a" VerticalAlignment="Bottom" Margin="10,0,10,8" Foreground="#aaa"/>
                    
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Fin" FontSize="10" Foreground="#666" Margin="0,0,0,5"/>
                        <ComboBox x:Name="EndHourCombo" Style="{StaticResource WorkHoursComboStyle}" ItemContainerStyle="{StaticResource WorkHoursItemStyle}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <Button Grid.Row="6"
                    Content="Guardar"
                    Click="SaveBtn_Click"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource SaveButtonStyle}"/>
        </Grid>
    </Border>
</Window>
