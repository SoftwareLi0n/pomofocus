<Window x:Class="FocusPomodoro.VentanaDescanso"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Break Time"
        WindowState="Maximized"
        WindowStyle="None"
        Topmost="True"
        Background="#0a0a1a"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="BreakButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4ade8090"/>
            <Setter Property="Foreground" Value="#fff"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="250"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5eeea0a0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0d0d16" Offset="0"/>
                <GradientStop Color="#161625" Offset="0.5"/>
                <GradientStop Color="#0d0d16" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Decoración de fondo (Brillos sutiles) -->
        <Ellipse Width="600" Height="600" Fill="#fbbf24" Opacity="0.03" Margin="-300,-300,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Ellipse Width="500" Height="500" Fill="#4ade80" Opacity="0.02" Margin="0,0,-250,-250" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="900">
            <!-- Icono y Título -->
            <TextBlock Text="Tiempo de Recarga"
                       FontSize="56"
                       FontWeight="ExtraBold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="20" Color="#fbbf24" Opacity="0.3" ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>

            <TextBlock Text="Has trabajado duro. Ahora tu mente necesita este espacio."
                       FontSize="22"
                       Foreground="#999"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,60"/>

            <!-- Contenedor del Timer (Glassmorphism) -->
            <Border Background="#1a1a2e80" 
                    BorderBrush="#33ffffff" 
                    BorderThickness="1" 
                    CornerRadius="30" 
                    Padding="60,40" 
                    Margin="0,0,0,50"
                    MaxWidth="600">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" HorizontalAlignment="Center">
                        <!-- Círculo de progreso de fondo -->
                        <Ellipse Width="200" Height="200" Stroke="#22ffffff" StrokeThickness="8"/>
                        
                        <!-- Círculo de progreso activo -->
                        <Canvas Width="190" Height="190" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path x:Name="ProgressArc"
                                  Stroke="#fbbf24"
                                  StrokeThickness="8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Canvas>

                        <!-- Tiempo -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="TimerText"
                                       Text="05:00"
                                       FontSize="56"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       FontFamily="Segoe UI Semibold"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Grid.Row="1" x:Name="StatusText"
                               Text="LISTO PARA COMENZAR"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#66fbbf24"
                               HorizontalAlignment="Center"
                               Margin="0,30,0,0"/>
                </Grid>
            </Border>

            <!-- Botones -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="StartBreakBtn"
                        Click="StartBreakBtn_Click"
                        Style="{StaticResource BreakButtonStyle}"
                        Width="280">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▶" Margin="0,0,12,0" FontSize="18" VerticalAlignment="Center"/>
                        <TextBlock Text="INICIAR DESCANSO" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="SkipBreakBtn"
                        Click="SkipBreakBtn_Click"
                        Background="Transparent"
                        Foreground="#555"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Margin="30,0,0,0"
                        Content="SALTAR DESCANSO ⏭">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#fbbf24"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </StackPanel>

        <TextBlock x:Name="MotivationText"
                   Text="&quot;El descanso no es una pérdida de tiempo, es parte del proceso de crecimiento.&quot;"
                   FontSize="16"
                   FontStyle="Italic"
                   Foreground="#444"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,40"/>
    </Grid>
</Window>
