<Window x:Class="FocusPomodoro.VentanaDescanso"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Break Time"
        WindowState="Maximized"
        WindowStyle="None"
        Topmost="True"
        Background="#0a0a1a"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="BreakButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4ade8090"/>
            <Setter Property="Foreground" Value="#fff"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="250"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5eeea0a0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0a0a1a" Offset="0"/>
                <GradientStop Color="#1a1a2e" Offset="0.5"/>
                <GradientStop Color="#0f0f23" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Contenido principal -->
        <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Height="691" Width="885">
            <TextBlock Text="☕ Hora del descanso"
                       FontSize="48"
                       FontWeight="Bold"
                       Foreground="#fbbf24"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Sesion completada! Tu mente necesita un descanso obligatorio."
                       FontSize="20"
                       Foreground="#888"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,60"/>

             <Border Background="#1a1a2e80" CornerRadius="20" Padding="40,30" Margin="0,0,0,40">
                 <StackPanel>
                     <TextBlock x:Name="TimerText"
                                Text="10:00"
                                FontSize="120"
                                FontWeight="Bold"
                                Foreground="#4ade80"
                                HorizontalAlignment="Center"
                                FontFamily="Consolas"/>

                      <!-- Progress Arc -->
                      <Canvas Width="200" Height="200" HorizontalAlignment="Center" Margin="0,20,0,20">
                          <Path x:Name="ProgressArc"
                                Stroke="#4ade80"
                                StrokeThickness="10"
                                Canvas.Left="50"
                                Canvas.Top="50"/>
                      </Canvas>

                     <TextBlock x:Name="StatusText"
                                Text="Listo para iniciar tu descanso"
                                FontSize="16"
                                Foreground="#aaa"
                                HorizontalAlignment="Center"
                                Margin="0,10,0,0"/>
                 </StackPanel>
             </Border>

            <Button x:Name="StartBreakBtn"
                    Click="StartBreakBtn_Click"
                    Style="{StaticResource BreakButtonStyle}"
                    HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="▶" Margin="0,0,10,0" FontSize="16"/>
                    <TextBlock Text="Iniciar descanso"/>
                </StackPanel>
            </Button>

            <Button x:Name="SkipBreakBtn"
                    Click="SkipBreakBtn_Click"
                    Background="Transparent"
                    Foreground="#666"
                    BorderThickness="0"
                    FontSize="13"
                    Cursor="Hand"
                    HorizontalAlignment="Center"
                    Margin="0,15,0,0"
                    Content="Saltar descanso ⏭"/>
        </StackPanel>

        <TextBlock Grid.Column="0" x:Name="MotivationText"
                   Text="Tomar descansos es esencial para la productividad. Relajate y recarga."
                   FontSize="14"
                   Foreground="#555"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,50"/>

        <!-- Sidebar de anuncios (derecha) - oculto temporalmente -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,30,0" Visibility="Collapsed">
            <TextBlock Text="Publicidad"
                       FontSize="18" Foreground="#666"
                       Margin="0,0,0,10"/>
            <Border Background="#1a1a2e40" CornerRadius="10" Padding="5" ClipToBounds="True">
                <wv2:WebView2 x:Name="AdWebView" Width="300" Height="780"
                              DefaultBackgroundColor="Transparent" Visibility="Collapsed"/>
            </Border>
        </StackPanel>
    </Grid>
</Window>
