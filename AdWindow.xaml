<Window x:Class="FocusPomodoro.AdWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sponsor" 
        Height="280" 
        Width="320"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        Closing="Window_Closing">

    <Border CornerRadius="15" 
            Background="#1a1a2e" 
            BorderBrush="#00d9ff" 
            BorderThickness="2">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" 
                       Text="Gracias por usar Focus Pomodoro" 
                       FontSize="14" 
                       FontWeight="Bold"
                       Foreground="#00d9ff" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <Border Grid.Row="1" 
                    Background="#2d2d4480" 
                    CornerRadius="10" 
                    Margin="0,0,0,10">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Tu espacio aqui" 
                               FontSize="24" 
                               FontWeight="Bold"
                               Foreground="#fff" 
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="contacto@tucorreo.com" 
                               FontSize="12" 
                               Foreground="#888" 
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="2" 
                       x:Name="CountdownText" 
                       Text="Cerrando en 5 segundos..." 
                       FontSize="11" 
                       Foreground="#aaa" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

            <ProgressBar Grid.Row="3" 
                         x:Name="AdProgressBar"
                         Height="4"
                         Background="#2d2d4480"
                         Foreground="#00d9ff"
                         Value="0"
                         Maximum="100"/>
        </Grid>
    </Border>
</Window>
