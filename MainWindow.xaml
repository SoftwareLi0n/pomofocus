<Window x:Class="FocusPomodoro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Focus Pomodoro"
        Height="320"
        Width="280"
        MinHeight="300"
        MinWidth="260"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- Boton de titulo (minimizar, cerrar) -->
        <Style x:Key="TitleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Width="22" Height="22">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#fff"/>
                    <Setter Property="Background" Value="#252535"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Boton circular de control (play/pause, reset) -->
        <Style x:Key="CircleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#252535"/>
            <Setter Property="Foreground" Value="#ccc"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="22" Width="44" Height="44">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333348"/>
                    <Setter Property="Foreground" Value="#fff"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Boton circular pequeno (settings, donate) -->
        <Style x:Key="SmallCircleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#777"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="16" Width="32" Height="32">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#ccc"/>
                    <Setter Property="Background" Value="#252535"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="22"
            Background="#0d0d16e0"
            BorderBrush="Transparent"
            BorderThickness="0"
            x:Name="MainBorder">
        <Grid Margin="16,10,16,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Barra superior: minimize/close -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="MinimizeBtn" Content="−"
                        Click="MinimizeBtn_Click" Style="{StaticResource TitleButtonStyle}"/>
                <Button x:Name="CloseBtn" Content="×" Margin="4,0,0,0"
                        Click="CloseBtn_Click" Style="{StaticResource TitleButtonStyle}"/>
            </StackPanel>

            <!-- Centro: Anillo de progreso + Timer -->
            <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Canvas Width="190" Height="190">
                    <!-- Track de fondo -->
                    <Ellipse Width="190" Height="190"
                             Stroke="#1a1a2e" StrokeThickness="7"
                             Fill="Transparent"/>
                    <!-- Arco de progreso -->
                    <Path x:Name="ProgressArc"
                          Stroke="#e85d04" StrokeThickness="7"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                </Canvas>
                <!-- Timer centrado sobre el anillo -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="TimerText" Text="50:00"
                               FontSize="46" FontWeight="Bold"
                               Foreground="#ffffff"
                               HorizontalAlignment="Center"
                               FontFamily="Consolas"/>
                    <TextBlock x:Name="StatusText" Text="READY"
                               FontSize="11" Foreground="#555"
                               HorizontalAlignment="Center"
                               FontWeight="SemiBold"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Barra inferior: Donate | Play/Reset | Settings -->
            <Grid Grid.Row="2" Margin="4,8,4,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Donate - extremo izquierdo -->
                <Button Grid.Column="0" x:Name="DonateBtn" Content="❤"
                        Click="DonateBtn_Click" ToolTip="Donate"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Style="{StaticResource SmallCircleButtonStyle}"/>

                <!-- Play/Pause + Reset - centro -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="PlayPauseBtn" Click="PlayPauseBtn_Click"
                            Style="{StaticResource CircleButtonStyle}">
                        <TextBlock x:Name="PlayPauseIcon" Text="▶" FontSize="16" Margin="2,0,0,0"/>
                    </Button>

                    <Button x:Name="ResetBtn" Click="ResetBtn_Click"
                            Style="{StaticResource CircleButtonStyle}"
                            Visibility="Collapsed" Margin="10,0,0,0">
                        <TextBlock Text="↺" FontSize="18"/>
                    </Button>
                </StackPanel>

                <!-- Settings - extremo derecho -->
                <Button Grid.Column="2" x:Name="SettingsBtn" Content="⚙"
                        Click="SettingsBtn_Click" ToolTip="Settings"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Style="{StaticResource SmallCircleButtonStyle}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
