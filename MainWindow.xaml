<Window x:Class="FocusPomodoro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Focus Pomodoro" 
        Height="280" 
        Width="320"
        MinHeight="200"
        MinWidth="250"
        Topmost="True"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <Style x:Key="TitleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#aaa"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Width="24" Height="24">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#fff"/>
                    <Setter Property="Background" Value="#ffffff20"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2d2d4480"/>
            <Setter Property="Foreground" Value="#fff"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" Padding="8,5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3d3d5480"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DistractedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#ff475790"/>
            <Setter Property="Foreground" Value="#fff"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" Padding="8,5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#ff6b7a90"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RefocusButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4ade8090"/>
            <Setter Property="Foreground" Value="#fff"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" Padding="8,5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5eeea0a0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HistoryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2d2d4480"/>
            <Setter Property="Foreground" Value="#00d9ff"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3d3d5480"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2d2d4480"/>
            <Setter Property="Foreground" Value="#fbbf24"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3d3d5480"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="15" 
            Background="#1a1a2ec0" 
            BorderBrush="#ffffff15" 
            BorderThickness="1"
            x:Name="MainBorder">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="MinimizeBtn" Content="−" Width="25" Height="25" 
                        Click="MinimizeBtn_Click" Style="{StaticResource TitleButtonStyle}"/>
                <Button x:Name="CloseBtn" Content="×" Width="25" Height="25" 
                        Click="CloseBtn_Click" Style="{StaticResource TitleButtonStyle}"/>
            </StackPanel>

            <TextBlock Grid.Row="1" x:Name="TimerText" Text="50:00" 
                       FontSize="48" FontWeight="Bold" 
                       Foreground="#00d9ff" 
                       HorizontalAlignment="Center"
                       FontFamily="Consolas"/>

            <TextBlock Grid.Row="2" x:Name="StatusText" Text="Listo para comenzar" 
                       FontSize="12" Foreground="#aaa" 
                       HorizontalAlignment="Center" Margin="0,5,0,10"/>

            <Grid Grid.Row="3" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="StartBtn" Content="Iniciar" 
                        Click="StartBtn_Click" Style="{StaticResource ActionButtonStyle}"/>
                <Button Grid.Column="1" x:Name="PauseBtn" Content="Pausar" 
                        Click="PauseBtn_Click" IsEnabled="False" 
                        Style="{StaticResource ActionButtonStyle}"/>
                <Button Grid.Column="2" x:Name="ResetBtn" Content="Reset" 
                        Click="ResetBtn_Click" Style="{StaticResource ActionButtonStyle}"/>
            </Grid>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="DistractedBtn" 
                        Content="Me distraje" 
                        Click="DistractedBtn_Click" 
                        IsEnabled="False"
                        Visibility="Visible"
                        Style="{StaticResource DistractedButtonStyle}"/>

                <Button Grid.Column="0" x:Name="RefocusBtn" 
                        Content="Volver a concentrarme" 
                        Click="RefocusBtn_Click" 
                        Visibility="Collapsed"
                        Style="{StaticResource RefocusButtonStyle}"/>

                <Button Grid.Column="1" x:Name="SettingsBtn" 
                        Content="⚙" 
                        Click="SettingsBtn_Click"
                        Width="40" Height="35"
                        Margin="5,0,0,0"
                        Style="{StaticResource SettingsButtonStyle}"/>

                <Button Grid.Column="2" x:Name="HistoryBtn" 
                        Content="📊" 
                        Click="HistoryBtn_Click"
                        Width="40" Height="35"
                        Margin="5,0,0,0"
                        Style="{StaticResource HistoryButtonStyle}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
